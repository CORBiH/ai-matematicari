# MAT-BOT — primjer .env fajla za VPS (docker compose čita ./.env kroz env_file).
# Kopiraj u .env i popuni STVARNE vrijednosti. NIKAD ne commituj pravi .env.

# ── Obavezno ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
FLASK_SECRET_KEY=REPLACE_ME_random_64_hex          # npr. `openssl rand -hex 32`

# ── Sigurnost (postaviti prije puštanja učenicima) ──────────────────────────
# ULAZ SAMO KROZ THINKIFIC — tri barijere koje rade zajedno; postavi SVE TRI:
#
# 1) EMBED_ALLOWED_ORIGINS — ko smije OTVORITI aplikaciju (GET /).
#    Bez odgovarajućeg Referer/Origin: 403 i token se NE kuje, pa je i tutor API
#    nedostupan. Prazno = kapija ISKLJUČENA (svako ko zna URL uđe). Wildcard radi.
EMBED_ALLOWED_ORIGINS=https://*.thinkific.com
# 2) AI_TUTOR_EMBED_SECRET — bez njega tutor API prolazi svakoga (kapija tada
#    štiti samo stranicu). Generiši: `openssl rand -hex 32`.
AI_TUTOR_EMBED_SECRET=REPLACE_ME_random_64_hex
# 3) FRAME_ANCESTORS — CSP: ko nas smije staviti u iframe. Prazno = bez CSP headera.
FRAME_ANCESTORS=https://*.thinkific.com
#
# Dozvoljeni CORS origini, zarezom odvojeni. Prazno = SVE domene (startup warning).
CORS_ORIGINS=https://tvoja-skola.thinkific.com,https://www.matematicari.com
# Tajna za /tasks/process (Cloud Tasks async tok). Prazno = endpoint odbija sve.
TASKS_SECRET=
# Token za dijagnostičke endpointe (/sheets/diag, /mathpix/selftest...). Prazno = zatvoreni.
DIAG_TOKEN=
# AI_TUTOR_EMBED_SECRET je gore, uz ostale barijere (vidi docs/deploy/embed-token.md).
AI_TUTOR_TOKEN_TTL_S=7200

# ── OpenAI modeli i vremena ─────────────────────────────────────────────────
OPENAI_MODEL_TEXT=gpt-5-mini
OPENAI_MODEL_VISION=gpt-5.2
OPENAI_TIMEOUT=120                                  # legacy /submit putanja
AI_TUTOR_TIMEOUT=45                                 # modularni tutor (kraće — učenik čeka)
AI_TUTOR_MAX_RETRIES=1
OPENAI_MAX_RETRIES=2

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=1
RATE_LIMIT_SUBMIT=30 per minute                     # po IP-u; škole iza NAT-a → povećaj

# ── Mathpix OCR (opciono; prazno = OCR isključen, ide Vision) ────────────────
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ── Google Sheets — puna transkripcija tutor razgovora (opciono) ─────────────
GSHEET_ID=
GSHEET_NAME=matematika-bot
GOOGLE_SHEETS_CREDENTIALS_B64=
SHEETS_ASYNC_LOG=1

# ── VPS/Docker ───────────────────────────────────────────────────────────────
PORT=8080
WEB_CONCURRENCY=1        # PAŽNJA: >1 workera + in-memory job store = async jobovi se gube
THREADS=8
GUNICORN_TIMEOUT=120
USE_FIRESTORE=0          # na VPS-u nema GCP kredencijala; jobovi idu u memoriju
COOKIE_SECURE=1
MAX_CONTENT_LENGTH_MB=20
IMAGE_FETCH_MAX_MB=20
# SQLite activity log (metapodaci tutora). Default: storage/matbot.sqlite3
# MATBOT_DB_PATH=/app/storage/matbot.sqlite3
# APP_VERSION postavlja deploy workflow automatski (git SHA).
# APP_VERSION=dev
